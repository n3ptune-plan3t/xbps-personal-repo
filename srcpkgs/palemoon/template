# Template file for 'palemoon'
pkgname=palemoon
version=34.1.0
revision=1
short_desc="Open source web browser based on Firefox focusing on efficiency"
maintainer="np <np@f.org>"
license="MPL-2.0, GPL-2.0-or-later, LGPL-2.1-or-later"
homepage="http://linux.palemoon.org/"
distfiles="https://rm-eu.palemoon.org/release/palemoon-${version}.linux-x86_64-gtk2.tar.xz
https://repo.palemoon.org/MoonchildProductions/Pale-Moon/raw/tag/${version}_Release/palemoon/branding/official/palemoon.desktop>palemoon.desktop"
checksum="da6e8e00854ce0af53883397c7b58c44309837c2afda519bb53fc087c8c16cc2
b3803b30b5e6b9589387b7162cd24247da242fe77c0aed0d09bc51338d36d7d8"
archs="x86_64*"
nostrip=yes
depends="alsa-lib dbus-glib desktop-file-utils gtk2 libxt mime-types nss"
conflicts="palemoon>=0"
provides="palemoon-${version}_${revision}"

do_install() {
        vcopy palemoon usr/lib
        vmkdir usr/bin
        ln -sf ../lib/palemoon/palemoon ${DESTDIR}/usr/bin/palemoon
        vinstall palemoon.desktop 644 usr/share/applications
        vinstall palemoon/browser/chrome/icons/default/default16.png \
                644 usr/share/icons/hicolor/16x16/apps palemoon.png
        vinstall palemoon/browser/chrome/icons/default/default32.png \
                644 usr/share/icons/hicolor/32x32/apps palemoon.png
        vinstall palemoon/browser/chrome/icons/default/default48.png \
                644 usr/share/icons/hicolor/48x48/apps palemoon.png
        vinstall palemoon/browser/icons/mozicon128.png \
                644 usr/share/icons/hicolor/128x128/apps palemoon.png
}
