# Template file for 'nebula-gtk'
pkgname=nebula-gtk
version=1.3.7
revision=1
build_style=cargo
hostmakedepends="pkg-config glib-devel desktop-file-utils"
makedepends="gtk4-devel libadwaita-devel pango-devel cairo-devel gdk-pixbuf-devel"
depends="dbus polkit"
short_desc="GTK/libadwaita frontend for Void Linux XBPS tooling"
maintainer="Orphaned <orphan@voidlinux.org>"
license="MIT"
homepage="https://github.com/Letdown2491/nebula-gtk"
changelog="https://github.com/Letdown2491/nebula-gtk/releases"
distfiles="https://github.com/Letdown2491/nebula-gtk/archive/refs/tags/v${version}.tar.gz"
checksum=f15c55a486f23d16146e701f43d5406927d0ec559fd3efe2adc61c0f42576b14

post_install() {
  vlicense LICENSE

  vinstall target/release/nebula-gtk 0755 usr/libexec

  vinstall assets/applications/tech.geektoshi.Nebula.desktop 0644 \
    usr/share/applications

  local icon
  for icon in assets/icons/hicolor/*/apps/*.png; do
    [ -e "$icon" ] || continue
    vinstall "$icon" 0644 "usr/share/icons/hicolor/${icon#assets/icons/hicolor/}"
  done
}
