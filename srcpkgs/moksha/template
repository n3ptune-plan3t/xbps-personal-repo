# Template file for 'moksha'
_commit=b11ceca00c556a9b6b5f1211cd0f5165d3a3b4b8
pkgname=moksha2
version=0.4.2
revision=1
build_style=gnu-configure
configure_args="--sysconfdir=/etc --disable-bodhi"
hostmakedepends="autoconf automake libtool pkg-config gettext efl"
makedepends="gettext-devel efl-devel pam-devel xkeyboard-config"
depends="desktop-file-utils hicolor-icon-theme xkeyboard-config"
conf_files="/etc/enlightenment/sysactions.conf"
short_desc="Enlightenment (E17) fork used by Bodhi Linux"
maintainer="wn <your@email.here>"
license="BSD-2-Clause"
homepage="https://github.com/JeffHoogland/moksha"
distfiles="https://github.com/JeffHoogland/moksha/archive/${_commit}.tar.gz"

checksum="f1f4b4972b5bee61a0d578bf4393e4b27ede18eb7dd2c1ed585551c87c6fc557"
lib32disabled=yes

wrksrc="moksha-${_commit}"

pre_configure() {
	autoreconf -fi
}

post_install() {
	# Use native tools for shutdown/suspend, same as Void's enlightenment pkg.
	sed -i 's/^action:.*halt.*/action: halt shutdown -p now/g' \
		${DESTDIR}/etc/enlightenment/sysactions.conf
	sed -i 's/^action:.*reboot.*/action: reboot shutdown -r now/g' \
		${DESTDIR}/etc/enlightenment/sysactions.conf
	sed -i 's/^action:.*suspend.*/action: suspend zzz/g' \
		${DESTDIR}/etc/enlightenment/sysactions.conf
	sed -i 's/^action:.*hibernate.*/action: hibernate ZZZ/g' \
		${DESTDIR}/etc/enlightenment/sysactions.conf

	vlicense COPYING
}

moksha-devel_package() {
	depends="efl-devel ${sourcepkg}>=${version}#_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
	}
}
