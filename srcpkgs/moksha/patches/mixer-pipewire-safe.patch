+           }
          return;

       case PA_CONTEXT_TERMINATED:
@@ -594,6 +650,12 @@ static Eina_Bool
 _epulse_connect(void *data)
 {
    pa_proplist *proplist;
    Epulse_Context *c = data;

+   /* Check if we've exceeded max reconnect attempts */
+   if (c->reconnect_attempts >= EPULSE_MAX_RECONNECT_ATTEMPTS)
+     {
+        return ECORE_CALLBACK_CANCEL;
+     }
+
    proplist = pa_proplist_new();
    pa_proplist_sets(proplist, PA_PROP_APPLICATION_NAME, "Efl Volume Control");
    pa_proplist_sets(proplist, PA_PROP_APPLICATION_ID,
@@ -622,6 +684,7 @@ _epulse_connect(void *data)
  err:
    pa_proplist_free(proplist);
    return ECORE_CALLBACK_RENEW;
 }

 int
 epulse_init(void)
@@ -633,6 +696,8 @@ epulse_init(void)
    ctx = calloc(1, sizeof(Epulse_Context));
    if (!ctx)
      {
         ERR("Could not create Epulse Context");
         return 0;
      }

+   ctx->reconnect_attempts = 0;
+   ctx->connect_timer = NULL;
+
    DISCONNECTED = ecore_event_type_new();
    SINK_ADDED = ecore_event_type_new();
@@ -673,6 +738,12 @@ epulse_shutdown(void)
    _init_count--;
    if (_init_count > 0)
      return;

+   if (ctx->connect_timer)
+     {
+        ecore_timer_del(ctx->connect_timer);
+        ctx->connect_timer = NULL;
+     }
+
    pa_context_unref(ctx->context);
    free(ctx);
    ctx = NULL;
