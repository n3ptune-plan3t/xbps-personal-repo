+static const char *
+_run_void_cmd(const char *action)
+{
+   /* Try loginctl first (works with elogind on Void) */
+   if (access("/usr/bin/loginctl", X_OK) == 0)
+     {
+        return _run_sudo("loginctl", action);
+     }
+   /* Fallback: direct poweroff/reboot (requires root) */
+   return _run_sudo(action, NULL);
+}
